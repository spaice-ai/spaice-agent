# SPAICE Agent config for {agent_id}
# Generated by `spaice-agent install --with-config` on {generated_at}
# Package version: {version}
#
# FILL IN the values marked TODO before the agent will work.
# Credentials go in ~/.Hermes/credentials/ — see project README.

agent_id: {agent_id}
memory_root: ~/{agent_id}            # TODO: point at your vault dir (must exist)

credentials:
  # Env-var names looked up from ~/.Hermes/credentials/ (JSON files)
  # or the process environment. See spaice_agent/credentials.py.
  openrouter_api_key_env: OPENROUTER_API_KEY
  exa_api_key_env: EXA_API_KEY
  brave_api_key_env: BRAVE_API_KEY

hook:
  total_timeout_s: 60.0

memory:
  enabled: true
  entity_cache_path: ~/{agent_id}/_dashboard/entity-cache.json
  stage_timeout_s: 2.0
  recall_max_hits_per_entity: 3
  recall_snippet_chars: 240
  live_capture_dir: ~/{agent_id}/_inbox

search:
  enabled: true
  daily_fire_cap: 50
  stage_timeout_s: 8.0
  providers:
    - name: exa
      endpoint: https://api.exa.ai/search
      max_results: 8
      per_request_timeout_s: 5.0
    - name: brave
      endpoint: https://api.search.brave.com/res/v1/web/search
      max_results: 8
      per_request_timeout_s: 5.0
  merge:
    method: rrf
    k: 60
  triggers:
    phrase_anchors:
      - '\blook up\b'
      - '\bfind me\b'
      - '\bsearch for\b'
      - '\bcurrent price of\b'
      - '\blatest release of\b'
      - '\bwho is\b'
    url_at_end: true

consensus:
  enabled: true
  daily_fire_cap: 50
  pipeline_timeout_s: 90.0
  advisory_suppress_turns: 3
  pipeline:
    - stage: proposer
      model: anthropic/claude-opus-4.7
      stage_timeout_s: 30.0
      max_tokens: 2048
      truncate_output_chars: 8000
      system: |
        You are chair 1 of 3 (proposer). Draft a first-pass answer.
        Chair 2 (critic) and chair 3 (reviewer) will follow. Be
        thorough but don't over-polish — gaps are the critic's job.
    - stage: critic
      model: openai/gpt-5-codex
      stage_timeout_s: 45.0
      max_tokens: 2048
      truncate_output_chars: 8000
      system: |
        You are chair 2 of 3 (critic). Find every weakness in chair 1's
        proposal: factual errors, hidden assumptions, missed risks,
        spec gaps. Surface problems only, numbered.
    - stage: reviewer
      model: deepseek/deepseek-v3.1-terminus
      stage_timeout_s: 45.0
      max_tokens: 3072
      truncate_output_chars: 12000
      system: |
        You are chair 3 of 3 (reviewer). Read proposal + critique.
        Produce a revised version that absorbs valid critiques and
        dismisses invalid ones. Explicitly call out rejections.
  triggers:
    words:
      - plan
      - decide
      - analyse
      - analyze
      - review
      - critique
      - audit
    phrases:
      - use consensus
      - second opinion
      - sanity check
      - pressure test
      - red team

scrubber:
  enabled: true
  leak_patterns:
    - '\b(sk|pk|key|token|password)[-_][A-Za-z0-9]{{16,}}\b'
    - '\bBearer\s+[A-Za-z0-9._-]{{16,}}\b'
